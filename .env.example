# Twitter (use cookies - get from x.com DevTools > Application > Cookies)
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
TWITTER_GUEST_ID=
TWITTER_TWID=
# Or use username/password (may be blocked by Cloudflare)
TWITTER_USERNAME=
TWITTER_PASSWORD=

# Bluesky
BLUESKY_USERNAME=yourhandle.bsky.social
BLUESKY_PASSWORD=your-app-password

# Target Twitter user to mirror (without @)
TARGET_USER=

# Check interval in seconds (default: 300)
CHECK_INTERVAL=300

# Translation (optional)
ENABLE_TRANSLATION=false
TRANSLATION_FROM=es
TRANSLATION_TO=en
TRANSLATOR_RAPIDAPI_KEY=

# Auto-update (optional)
AUTO_UPDATE=true
# Seconds
UPDATE_CHECK_INTERVAL=86400
